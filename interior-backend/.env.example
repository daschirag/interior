# Server (Render sets PORT automatically)
PORT=5000
HOST=0.0.0.0

# CORS — comma-separated production URLs (localhost is always allowed unless DISALLOW_LOCAL_ORIGINS=true)
# ALLOWED_ORIGINS=https://your-site.vercel.app,https://your-admin.vercel.app
# Legacy alias still supported: CORS_ORIGIN=...
# DISALLOW_LOCAL_ORIGINS=true

# Supabase — prefer Session Pooler connection string on Render (IPv4-compatible)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# Set false on Render if using pooler and you see connection issues (optional)
# DB_FORCE_IPV4=false

# JWT
JWT_SECRET=your-long-random-secret-string

# ImageKit (direct browser upload — backend only issues short-lived auth tokens)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
