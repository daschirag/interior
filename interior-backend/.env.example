# Server
PORT=5000

# Comma-separated allowed origins in production (unset = allow all, fine for local dev)
# CORS_ORIGIN=https://your-site.onrender.com,https://www.vinayakinteriors.com

# Supabase PostgreSQL (use either block below)
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# Or single connection string (optional alternative)
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-long-random-secret-string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
